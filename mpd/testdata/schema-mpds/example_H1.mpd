<?xml version="1.0"?>
<MPD xmlns="urn:mpeg:dash:schema:mpd:2011" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="urn:mpeg:dash:schema:mpd:2011 DASH-MPD.xsd" profiles="urn:mpeg:dash:profile:isoff-on-demand:2011" type="static" mediaPresentationDuration="PT10S" minBufferTime="PT1S">
  <ProgramInformation>
    <Title>Example of a DASH Media Presentation Description using Spatial Relationship Description to indicate that a video is a zoomed part of another</Title>
  </ProgramInformation>
  <Period>
    <AdaptationSet segmentAlignment="true" subsegmentAlignment="true" subsegmentStartsWithSAP="1">
      <SupplementalProperty schemeIdUri="urn:mpeg:dash:srd:2014" value="0,0,0,3,3,3,3"></SupplementalProperty>
      <Role schemeIdUri="urn:mpeg:dash:role:2011" value="main"></Role>
      <Representation id="1" bandwidth="1055223" width="1920" height="1080" mimeType="video/mp4" codecs="avc1.42c033" startWithSAP="1">
        <BaseURL> panorama_video.mp4</BaseURL>
        <SegmentBase indexRange="839-990" indexRangeExact="true"></SegmentBase>
      </Representation>
    </AdaptationSet>
    <AdaptationSet segmentAlignment="true" subsegmentAlignment="true" subsegmentStartsWithSAP="1">
      <SupplementalProperty schemeIdUri="urn:mpeg:dash:srd:2014" value="0,1,1,1,1,3,3"></SupplementalProperty>
      <Role schemeIdUri="urn:mpeg:dash:role:2011" value="supplementary"></Role>
      <Representation id="2" bandwidth="769458" width="1920" height="1080" mimeType="video/mp4" codecs="avc1.42c028" startWithSAP="1">
        <BaseURL> zoomed_video.mp4</BaseURL>
        <SegmentBase indexRange="838-989" indexRangeExact="true"></SegmentBase>
      </Representation>
    </AdaptationSet>
  </Period>
</MPD>
