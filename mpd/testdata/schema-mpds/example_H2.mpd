      <Representation id="6" bandwidth="769514" width="1920" height="1080" mimeType="video/mp4" codecs="avc1.42c028" startWithSAP="1">
        <BaseURL> tile1_video_fullhd.mp4</BaseURL>
        <SegmentBase indexRange="839-990" indexRangeExact="true"></SegmentBase>
      </Representation>
    </AdaptationSet>
    <AdaptationSet segmentAlignment="true" subsegmentAlignment="true" subsegmentStartsWithSAP="1">
      <SupplementalProperty schemeIdUri="urn:mpeg:dash:srd:2014" value="0,1,0,1,1,2,2"></SupplementalProperty>
    </AdaptationSet>
    <AdaptationSet segmentAlignment="true" subsegmentAlignment="true" subsegmentStartsWithSAP="1">
      <SupplementalProperty schemeIdUri="urn:mpeg:dash:srd:2014" value="0,1,1,1,1,2,2"></SupplementalProperty>
