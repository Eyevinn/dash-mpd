<?xml version="1.0"?>
<MPD xmlns="urn:mpeg:dash:schema:mpd:2011" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="urn:mpeg:dash:schema:mpd:2011 DASH-MPD.xsd" profiles="urn:mpeg:dash:profile:isoff-on-demand:2011" type="static" mediaPresentationDuration="PT10S" minBufferTime="PT1S">
  <ProgramInformation>
    <Title>Example of a DASH Media Presentation Description using Spatial Relationship Description to indicate tiles of a video</Title>
  </ProgramInformation>
  <Period>
    <AdaptationSet segmentAlignment="true" subsegmentAlignment="true" subsegmentStartsWithSAP="1">
      <SupplementalProperty schemeIdUri="urn:mpeg:dash:srd:2014" value="0,0,0,2,2,2,2"></SupplementalProperty>
      <Role schemeIdUri="urn:mpeg:dash:role:2011" value="main"></Role>
      <Representation id="1" bandwidth="226597" width="640" height="360" mimeType="video/mp4" codecs="avc1.42c01e" startWithSAP="1">
        <BaseURL> full_video_small.mp4</BaseURL>
        <SegmentBase indexRange="837-988" indexRangeExact="true"></SegmentBase>
      </Representation>
      <Representation id="2" bandwidth="553833" width="1280" height="720" mimeType="video/mp4" codecs="avc1.42c01f" startWithSAP="1">
        <BaseURL> full_video_hd.mp4</BaseURL>
        <SegmentBase indexRange="838-989" indexRangeExact="true"></SegmentBase>
      </Representation>
      <Representation id="3" bandwidth="1055223" width="3840" height="2160" mimeType="video/mp4" codecs="avc1.42c033" startWithSAP="1">
        <BaseURL> full_video_4k.mp4</BaseURL>
        <SegmentBase indexRange="839-990" indexRangeExact="true"></SegmentBase>
      </Representation>
    </AdaptationSet>
    <AdaptationSet segmentAlignment="true" subsegmentAlignment="true" subsegmentStartsWithSAP="1">
      <SupplementalProperty schemeIdUri="urn:mpeg:dash:srd:2014" value="0,0,0,1,1,2,2"></SupplementalProperty>
      <Role schemeIdUri="urn:mpeg:dash:role:2011" value="supplementary"></Role>
      <Representation id="4" bandwidth="218284" width="640" height="360" mimeType="video/mp4" codecs="avc1.42c00d" startWithSAP="1">
        <BaseURL> tile1_video_small.mp4</BaseURL>
        <SegmentBase indexRange="837-988" indexRangeExact="true"></SegmentBase>
      </Representation>
      <Representation id="5" bandwidth="525609" width="1280" height="720" mimeType="video/mp4" codecs="avc1.42c01f" startWithSAP="1">
        <BaseURL> tile1_video_hd.mp4</BaseURL>
        <SegmentBase indexRange="838-989" indexRangeExact="true"></SegmentBase>
